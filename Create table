-- 1. Create the Members table
CREATE TABLE Members (
    MemberID INT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    JoinDate DATE NOT NULL,
    MembershipType VARCHAR(50), -- e.g., 'Basic', 'Premium', 'VIP'
    MonthlyFee DECIMAL(10, 2)
);

-- 2. Create the Attendance table
-- This connects to Members via MemberID
CREATE TABLE Attendance (
    LogID INT PRIMARY KEY,
    MemberID INT,
    VisitDate DATE NOT NULL,
    MinutesSpent INT,
    FOREIGN KEY (MemberID) REFERENCES Members(MemberID)
);

-- 3. Create the Cancellations table
-- This also connects back to the original MemberID
CREATE TABLE Cancellations (
    CancelID INT PRIMARY KEY,
    MemberID INT,
    CancelDate DATE NOT NULL,
    Reason VARCHAR(255), -- e.g., 'Moving', 'Too Expensive', 'Injury'
    FOREIGN KEY (MemberID) REFERENCES Members(MemberID)
);
